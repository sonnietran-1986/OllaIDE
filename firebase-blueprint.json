{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Thông tin người dùng và cài đặt cá nhân.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "sessions": {
      "title": "Chat Session",
      "description": "Phiên làm việc của AI Agent.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "messages": {
      "title": "Chat Message",
      "description": "Tin nhắn trong phiên làm việc.",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "role", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Thông tin người dùng."
    },
    "/sessions/{sessionId}": {
      "schema": "sessions",
      "description": "Danh sách các phiên chat."
    },
    "/sessions/{sessionId}/messages/{messageId}": {
      "schema": "messages",
      "description": "Chi tiết tin nhắn trong phiên chat."
    }
  }
}
